{
  "name": "@seekstar/core-schema",
  "version": "0.0.0",
  "private": true,
  "description": "Shared SeekStar semantic terrain contracts.",
  "type": "module",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "node -e \"fs.rmSync('dist', { recursive: true, force: true })\""
  },
  "devDependencies": {
    "typescript": "^6.0.3"
  }
}
