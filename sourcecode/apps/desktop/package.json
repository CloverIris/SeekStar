{
  "name": "@seekstar/desktop",
  "version": "0.0.0",
  "private": true,
  "description": "SeekStar Electron desktop observatory.",
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "tsc --noEmit && electron-vite build",
    "typecheck": "tsc --noEmit",
    "preview": "electron-vite preview",
    "clean": "node -e \"fs.rmSync('out', { recursive: true, force: true }); fs.rmSync('dist', { recursive: true, force: true })\""
  },
  "dependencies": {
    "@seekstar/constellation-engine": "0.0.0",
    "@seekstar/core-schema": "0.0.0",
    "@seekstar/ai-service": "0.0.0",
    "@seekstar/scout-service": "0.0.0",
    "@seekstar/storage-service": "0.0.0",
    "lucide-react": "^1.21.0",
    "pixi.js": "^8.19.0",
    "playwright": "^1.61.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "electron-vite": "^5.0.0",
    "typescript": "^6.0.3",
    "vite": "^7.3.0"
  }
}
